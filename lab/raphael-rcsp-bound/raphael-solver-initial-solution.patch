+
+    fn solution_from_actions(&self, actions: &[Action]) -> Result<Solution, SolverException> {
+        let mut state = SimulationState::new(&self.settings.simulator_settings);
+        let mut solver_actions = Vec::new();
+        let mut steps = 0;
+        let mut duration = 0;
+        for action in actions {
+            let solver_action = ActionCombo::Single(*action);
+            state = use_action_combo(&self.settings, state, solver_action)
+                .map_err(|_| SolverException::NoSolution)?;
+            solver_actions.push(solver_action);
+            steps += solver_action.steps();
+            duration += solver_action.duration();
+        }
+        if state.progress < self.settings.max_progress()
+            || (!self.settings.allow_non_max_quality_solutions
+                && state.quality < self.settings.max_quality())
+        {
+            return Err(SolverException::NoSolution);
+        }
+        let search_score = SearchScore {
+            quality_upper_bound: std::cmp::min(state.quality, self.settings.max_quality()),
+            steps_lower_bound: steps,
+            duration_lower_bound: duration,
+            current_steps: steps,
+            current_duration: duration,
+        };
+        Ok(Solution {
+            score: (search_score, state.quality),
+            solver_actions,
+        })
+    }
